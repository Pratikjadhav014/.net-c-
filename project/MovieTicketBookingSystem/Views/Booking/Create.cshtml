@model MovieTicketBookingSystem.Models.Booking

@{
    ViewData["Title"] = "Book Ticket";
    var show = ViewBag.ShowDetails as MovieTicketBookingSystem.Models.Show;
}

<h1>Book Ticket</h1>

@if (show != null)
{
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h4 class="card-title">@show.Movie!.MovieName</h4>
            <h6 class="card-subtitle mb-2 text-muted">@show.Movie.Genre | @show.Movie.Duration mins</h6>
            <p class="card-text">
                <strong>Show Time:</strong> @show.ShowTime.ToString("f") <br />
                <strong>Available Seats:</strong> <span class="badge bg-success">@show.AvailableSeats</span>
            </p>
        </div>
    </div>
}

<hr />
<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="MovieId" />
            <input type="hidden" asp-for="ShowId" />

            <div class="form-group mb-3">
                <label asp-for="UserName" class="control-label">Full Name</label>
                <input asp-for="UserName" class="form-control" placeholder="Enter your full name" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="MobileNumber" class="control-label">Mobile Number</label>
                <input asp-for="MobileNumber" class="form-control" placeholder="10-digit mobile number" />
                <span asp-validation-for="MobileNumber" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="SeatsBooked" class="control-label">Number of Seats</label>
                <input asp-for="SeatsBooked" class="form-control" min="1" max="@(show?.AvailableSeats ?? 100)" />
                <span asp-validation-for="SeatsBooked" class="text-danger"></span>
            </div>
            
            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary btn-lg w-100">Confirm Booking</button>
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Movie" asp-action="Index" class="btn btn-secondary">Cancel and Back to Movies</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
