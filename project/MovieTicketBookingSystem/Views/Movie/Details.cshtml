@model MovieTicketBookingSystem.Models.Movie

@{
    ViewData["Title"] = "Movie Details";
}

<h1>Movie Details</h1>

<div>
    <h4>@Model.MovieName</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Genre)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Genre)</dd>
        
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Duration)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Duration) mins</dd>
    </dl>
</div>

<h3 class="mt-4">Available Shows</h3>
@if (Model.Shows != null && Model.Shows.Any())
{
    <table class="table table-bordered mt-2">
        <thead class="table-light">
            <tr>
                <th>Show Time</th>
                <th>Available Seats</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var show in Model.Shows.OrderBy(s => s.ShowTime))
        {
            <tr>
                <td>@show.ShowTime.ToString("f")</td>
                <td>@show.AvailableSeats</td>
                <td>
                    @if(show.AvailableSeats > 0)
                    {
                        <a asp-controller="Booking" asp-action="Create" asp-route-showId="@show.ShowId" class="btn btn-success btn-sm">Book Ticket</a>
                    }
                    else
                    {
                        <span class="text-danger fw-bold">Housefull</span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-warning">No shows available for this movie yet.</div>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.MovieId" class="btn btn-warning">Edit Movie</a> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
